{
  "compilerOptions": {
    "target": "es2016",
    "lib": ["es2016"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "isolatedDeclarations": true
  },
  "include": [
    "packages",
    "build.ts",
    "release.ts",
    "global.d.ts",
    "vitest.setup.ts",
    "vitest.config.ts"
  ]
}
